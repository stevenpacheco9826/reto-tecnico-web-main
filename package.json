{
  "name": "reto-tecnico-web",
  "version": "1.0.0",
  "description": "Proyecto de automatización con Playwright, Cucumber y Page Object Model (POM) para Orange HRM",
  "main": "index.js",
  "scripts": {
    "test": "npx cucumber-js",
    "test:debug": "PWDEBUG=1 npx cucumber-js",
    "test:headless": "npx cucumber-js --format progress",
    "test:report": "open reports/report.html"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "automation",
    "testing",
    "pom"
  ],
  "author": "Steven Pacheco",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "ts-node": "^10.9.2"
  }
}
